desc:MMM Global Options

slider1:jsfx_id=54964318<54964318, 54964318, 1>-jsfx_id

// Core generation parameters
slider10:temperature=1.0<0.5, 2.0, 0.1>Temperature
slider11:model_dim=4<2, 8, 1>Model Dimension
slider12:sampling_seed=-1<-1, 9999, 1>Sampling Seed (-1 = random)
slider13:mask_top_k=0<0, 50, 1>Top K (0 = disabled)
slider14:mask_top_p=0<0, 0.99, 0.01>Top P (0 = disabled)

in_pin:none
out_pin:none

@init
// Store previous values for validation
temp_prev = temperature;
md_prev = model_dim;

@slider
// Validate parameter relationships
model_dim < bars_per_step ? (
  model_dim = bars_per_step;
);

// Enforce temperature range [0.5, 2.0] - MidiGPT requirement
temperature < 0.5 ? (
  temperature = 0.5;
);

temperature > 2.0 ? (
  temperature = 2.0;
);

// Store current values
temp_prev = temperature;
md_prev = model_dim;